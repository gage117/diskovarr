<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Diskovarr View</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <meta property="og:site_name" content="Diskovarr">
  <meta property="og:title" content="Diskovarr View">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css?v=13">
  <link rel="stylesheet" href="/css/discover.css?v=3">
  <link rel="stylesheet" href="/theme.css?c=<%= themeParam %>">
</head>
<body>
  <%- include('partials/nav', { username, thumb, currentPath }) %>

  <main class="main-content">
    <div class="hero" style="margin-bottom:28px">
      <h1 class="hero-title">🔍 Diskovarr View</h1>
      <p class="hero-sub">Browse and filter your entire library</p>
    </div>

    <!-- ── Filters ─────────────────────────────────────────────────── -->
    <div class="filter-bar" id="filter-bar">

      <!-- Type -->
      <div class="filter-group">
        <label class="filter-label">Type</label>
        <div class="filter-chips" id="filter-type">
          <button class="chip active" data-value="all">All</button>
          <button class="chip" data-value="movie">Movies</button>
          <button class="chip" data-value="show">TV Shows</button>
          <button class="chip" data-value="anime">Anime</button>
        </div>
      </div>

      <!-- Decade -->
      <div class="filter-group">
        <label class="filter-label">Decade</label>
        <div class="filter-chips" id="filter-decade">
          <button class="chip active" data-value="">Any</button>
          <button class="chip" data-value="2020">2020s</button>
          <button class="chip" data-value="2010">2010s</button>
          <button class="chip" data-value="2000">2000s</button>
          <button class="chip" data-value="1990">1990s</button>
          <button class="chip" data-value="1980">1980s</button>
          <button class="chip" data-value="1970">1970s</button>
        </div>
      </div>

      <!-- Min Rating -->
      <div class="filter-group">
        <label class="filter-label">Min Rating: <span id="rating-value">Any</span></label>
        <input type="range" id="filter-rating" min="0" max="9" step="1" value="0" class="rating-slider">
        <div class="rating-ticks">
          <span>Any</span><span>5</span><span>6</span><span>7</span><span>7.5</span><span>8</span><span>8.5</span><span>9</span><span>9.5</span><span>10</span>
        </div>
      </div>

      <!-- Sort -->
      <div class="filter-group">
        <label class="filter-label">Sort by</label>
        <select id="filter-sort" class="filter-select">
          <option value="rating">Highest Rated</option>
          <option value="added">Recently Added</option>
          <option value="year_desc">Newest First</option>
          <option value="year_asc">Oldest First</option>
          <option value="title">A–Z</option>
        </select>
      </div>

      <!-- Genres -->
      <div class="filter-group filter-group-full">
        <label class="filter-label">Genres <span class="filter-clear-genres" id="clear-genres" style="display:none">— Clear</span></label>
        <div class="genre-chips" id="filter-genres">
          <span class="genre-loading">Loading genres...</span>
        </div>
      </div>

      <!-- Include watched -->
      <div class="filter-group">
        <label class="filter-label include-watched-label">
          <input type="checkbox" id="filter-include-watched">
          Include already watched
        </label>
      </div>
    </div>

    <!-- ── Results ─────────────────────────────────────────────────── -->
    <div class="discover-results-header" id="results-header" style="display:none">
      <span id="results-count" class="results-count"></span>
      <button class="chip-sm" id="btn-clear-filters" onclick="clearAllFilters()">Clear all filters</button>
    </div>

    <div class="card-grid" id="discover-grid">
      <div class="discover-empty" id="discover-initial">
        <div class="discover-empty-icon">◈</div>
        <p>Set your filters above and results will appear here</p>
      </div>
    </div>

    <div id="load-more-wrap" style="display:none; text-align:center; padding:32px 0">
      <button class="btn-load-more" id="btn-load-more" onclick="loadMore()">Load more</button>
    </div>
  </main>

  <script>
    window.DISKOVARR = { userId: "<%= userId %>" };
  </script>
  <script src="/js/watchlist.js?v=7"></script>
  <script src="/js/app.js?v=8"></script>
  <script src="/js/discover.js?v=4"></script>
</body>
</html>
