<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Diskovarr</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/nav', { username, thumb }) %>

  <main class="main-content">
    <div class="hero">
      <h1 class="hero-title">Welcome back, <span class="accent"><%= username %></span></h1>
      <p class="hero-sub">Personalized picks based on your watch history</p>
    </div>

    <!-- Top Picks -->
    <section class="section" id="section-top-picks">
      <div class="section-header">
        <h2 class="section-title">Top Picks for You</h2>
        <span class="section-badge">Personalized</span>
      </div>
      <div class="card-grid skeleton-grid" id="grid-top-picks">
        <% for(let i = 0; i < 6; i++) { %>
          <div class="card card-skeleton">
            <div class="skeleton-poster shimmer"></div>
            <div class="skeleton-info">
              <div class="skeleton-line shimmer" style="width:80%"></div>
              <div class="skeleton-line shimmer" style="width:50%"></div>
            </div>
          </div>
        <% } %>
      </div>
    </section>

    <!-- Movies -->
    <section class="section" id="section-movies">
      <div class="section-header">
        <h2 class="section-title">Movies</h2>
      </div>
      <div class="card-grid skeleton-grid" id="grid-movies">
        <% for(let i = 0; i < 6; i++) { %>
          <div class="card card-skeleton">
            <div class="skeleton-poster shimmer"></div>
            <div class="skeleton-info">
              <div class="skeleton-line shimmer" style="width:70%"></div>
              <div class="skeleton-line shimmer" style="width:40%"></div>
            </div>
          </div>
        <% } %>
      </div>
    </section>

    <!-- TV Shows -->
    <section class="section" id="section-tv">
      <div class="section-header">
        <h2 class="section-title">TV Shows</h2>
      </div>
      <div class="card-grid skeleton-grid" id="grid-tv">
        <% for(let i = 0; i < 6; i++) { %>
          <div class="card card-skeleton">
            <div class="skeleton-poster shimmer"></div>
            <div class="skeleton-info">
              <div class="skeleton-line shimmer" style="width:75%"></div>
              <div class="skeleton-line shimmer" style="width:45%"></div>
            </div>
          </div>
        <% } %>
      </div>
    </section>

    <!-- Anime -->
    <section class="section" id="section-anime">
      <div class="section-header">
        <h2 class="section-title">Anime</h2>
      </div>
      <div class="card-grid skeleton-grid" id="grid-anime">
        <% for(let i = 0; i < 6; i++) { %>
          <div class="card card-skeleton">
            <div class="skeleton-poster shimmer"></div>
            <div class="skeleton-info">
              <div class="skeleton-line shimmer" style="width:65%"></div>
              <div class="skeleton-line shimmer" style="width:35%"></div>
            </div>
          </div>
        <% } %>
      </div>
    </section>
  </main>

  <script>
    // Inject minimal config — NO tokens or API keys
    window.DISKOVARR = {
      userId: "<%= userId %>"
    };
  </script>
  <script src="/js/watchlist.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
