<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Diskovarr — Watchlist</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css?v=4">
  <link rel="stylesheet" href="/theme.css?c=<%= themeParam %>">
</head>
<body>
  <%- include('partials/nav', { username, thumb, currentPath }) %>

  <main class="main-content">
    <div class="hero">
      <h1 class="hero-title">Your <span class="accent">Watchlist</span></h1>
      <p class="hero-sub"><%= items.length %> saved item<%= items.length !== 1 ? 's' : '' %></p>
    </div>

    <% if (items.length === 0) { %>
      <div class="watchlist-empty">
        <p class="watchlist-empty-msg">Nothing saved yet.</p>
        <p class="watchlist-empty-sub">Browse recommendations and hit <strong>+ Watchlist</strong> to save things to watch later.</p>
        <a href="/" class="btn-plex" style="display:inline-block;margin-top:1rem;">Browse Recommendations</a>
      </div>
    <% } else { %>
      <section class="section">
        <div class="card-grid" id="watchlist-grid">
          <% for (const item of items) { %>
            <div class="card" id="wl-card-<%= item.ratingKey %>" data-rating-key="<%= item.ratingKey %>">
              <button class="card-poster-link" type="button" title="<%= item.title %>" data-rating-key="<%= item.ratingKey %>">
                <% if (item.thumb) { %>
                  <img class="card-poster" src="/api/poster?path=<%= encodeURIComponent(item.thumb) %>" alt="<%= item.title %>" loading="lazy">
                <% } else { %>
                  <div class="card-poster card-poster-placeholder">🎬<span><%= item.title %></span></div>
                <% } %>
              </button>
              <div class="card-info">
                <div class="card-title"><%= item.title %></div>
                <div class="card-meta">
                  <span class="card-year"><%= item.year || '' %></span>
                  <% if (item.audienceRating) { %>
                    <span class="card-rating">★ <%= item.audienceRating.toFixed(1) %></span>
                  <% } %>
                </div>
                <button class="wl-remove-btn" data-rating-key="<%= item.ratingKey %>">✕ Remove</button>
              </div>
            </div>
          <% } %>
        </div>
      </section>
    <% } %>
  </main>

  <script>
    // Item data for modal — embedded server-side, no tokens exposed
    window._wlItems = <%- JSON.stringify(items) %>;
  </script>
  <script src="/js/watchlist.js?v=5"></script>
  <script src="/js/app.js?v=5"></script>
  <script>
    // Build lookup map and wire poster clicks to modal
    var itemMap = {};
    (window._wlItems || []).forEach(function (item) { itemMap[item.ratingKey] = item; });
    document.querySelectorAll('.card-poster-link').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var item = itemMap[btn.dataset.ratingKey];
        if (item && window.openModal) window.openModal(item);
      });
    });

    document.querySelectorAll('.wl-remove-btn').forEach(function (btn) {
      btn.addEventListener('click', async function () {
        const ratingKey = btn.dataset.ratingKey;
        btn.disabled = true;
        btn.textContent = 'Removing...';
        try {
          await Watchlist.remove(ratingKey);
          const card = document.getElementById('wl-card-' + ratingKey);
          if (card) {
            card.style.transition = 'opacity 0.25s';
            card.style.opacity = '0';
            setTimeout(function () {
              card.remove();
              var remaining = document.querySelectorAll('#watchlist-grid .card').length;
              var sub = document.querySelector('.hero-sub');
              if (sub) sub.textContent = remaining + ' saved item' + (remaining !== 1 ? 's' : '');
              if (remaining === 0) {
                document.querySelector('.section').remove();
                document.querySelector('main').insertAdjacentHTML('beforeend',
                  '<div class="watchlist-empty"><p class="watchlist-empty-msg">Nothing saved yet.</p>' +
                  '<p class="watchlist-empty-sub">Browse recommendations and hit <strong>+ Watchlist</strong> to save things to watch later.</p>' +
                  '<a href="/" class="btn-plex" style="display:inline-block;margin-top:1rem;">Browse Recommendations</a></div>');
              }
            }, 250);
          }
        } catch (err) {
          btn.disabled = false;
          btn.textContent = '✕ Remove';
          alert('Failed to remove. Try again.');
        }
      });
    });
  </script>
</body>
</html>
